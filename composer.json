{
    "name": "conductor/orkes-laravel",
    "description": "Conductor PHP SDK and Laravel integration (Orkes & Netflix Conductor)",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/config": "^11.0|^12.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "phpstan/phpstan": "^1.0",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Conductor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Conductor\\Tests\\": "tests/",
            "Conductor\\Laravel\\Tests\\": "tests/Laravel/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "extra": {
        "laravel": {
            "providers": [
                "Conductor\\Laravel\\Providers\\ConductorServiceProvider"
            ],
            "aliases": {
                "Conductor": "Conductor\\Laravel\\Facades\\Conductor"
            }
        },
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "prefer-stable": true
}
